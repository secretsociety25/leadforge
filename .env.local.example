NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Project Settings → API: copy the anon (public) key exactly — may be a long JWT (eyJ…) or a newer publishable key (sb_publishable_…), depending on your project.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only — used for profile sync, webhooks, admin DB updates (RLS bypass). Must be the real service_role secret (JWT), not the text "your_service_role_key_here".
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Postgres URI for applying migrations (npm run db:migrate). Dashboard → Settings → Database → Connection string (URI). Replace the whole placeholder with your real URI — not "your_full_postgresql_url_here".
# DATABASE_URL=postgresql://postgres.[ref]:[YOUR-DB-PASSWORD]@aws-0-....pooler.supabase.com:6543/postgres
# Optional alias (same value as Supabase service role).
# ZIINA_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL — used for email-confirm redirects, metadata, and absolute links. MUST match the live hostname (include https and www if you use them).
# Production example: https://www.mtdfix.co.uk
# Local dev: must match the port Next prints (e.g. http://localhost:3000 or http://localhost:3006)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase Dashboard → Authentication → URL Configuration (required for production) ---
# Site URL: https://www.mtdfix.co.uk (or your canonical origin)
# Additional Redirect URLs (add each on its own line):
#   https://www.mtdfix.co.uk/**
#   https://www.mtdfix.co.uk/auth/callback
#   http://localhost:3000/**
#   http://localhost:3000/auth/callback
# If you use apex + www, add both hosts or redirect one to the other in Vercel/DNS.

# LeadForge Alpha — Claude 3.5 Sonnet email drafts. Server-only.
ANTHROPIC_API_KEY=
# Optional override (default: claude-3-5-sonnet-20241022)
# ANTHROPIC_MODEL=

# Legacy / other features — optional.
OPENAI_API_KEY=

# Ziina Payment Intent API — Bearer token (Dashboard / Connect).
ZIINA_API_KEY=
# Legacy alias if you still use OAuth access token:
# ZIINA_ACCESS_TOKEN=

# Optional HMAC verification for POST /api/ziina/webhook (x-hmac-signature). Omit for local MVP only.
ZIINA_WEBHOOK_SECRET=

# Optional API base (default https://api-v2.ziina.com/api).
# ZIINA_API_BASE_URL=https://api-v2.ziina.com/api

# List prices: lib/plans.ts — AED (UAE), GBP (UK), EUR (Euro area). Amounts are minor units per Ziina.
